<%- include("../partials/head", { title: "Mentee Profile" }) %>
<%- include("../partials/header") %>
<main class="container">
  <div class="inline-form wrap page-head-row">
    <h1>Mentee Profile Setup</h1>
    <a class="btn ghost" href="/manuals/mentee-manual.html" target="_blank" rel="noopener noreferrer">Mentee User Manual</a>
  </div>
  <%- include("../partials/flash") %>
  <section class="card">
    <form method="post" action="/mentee/profile" class="form-grid">
      <label>Title
        <select name="title">
          <option value="" <%= !profile?.title ? 'selected' : '' %>>Select title</option>
          <option value="Mr" <%= profile?.title === 'Mr' ? 'selected' : '' %>>Mr</option>
          <option value="Mrs" <%= profile?.title === 'Mrs' ? 'selected' : '' %>>Mrs</option>
          <option value="Ms" <%= profile?.title === 'Ms' ? 'selected' : '' %>>Ms</option>
          <option value="Miss" <%= profile?.title === 'Miss' ? 'selected' : '' %>>Miss</option>
          <option value="Mx" <%= profile?.title === 'Mx' ? 'selected' : '' %>>Mx</option>
          <option value="Dr" <%= profile?.title === 'Dr' ? 'selected' : '' %>>Dr</option>
          <option value="Prof" <%= profile?.title === 'Prof' ? 'selected' : '' %>>Prof</option>
          <option value="Rev" <%= profile?.title === 'Rev' ? 'selected' : '' %>>Rev</option>
        </select>
      </label>

      <label>Pronouns
        <select name="pronouns">
          <option value="" <%= !profile?.pronouns ? 'selected' : '' %>>Select pronouns</option>
          <option value="she/her" <%= profile?.pronouns === 'she/her' ? 'selected' : '' %>>she/her</option>
          <option value="he/him" <%= profile?.pronouns === 'he/him' ? 'selected' : '' %>>he/him</option>
          <option value="they/them" <%= profile?.pronouns === 'they/them' ? 'selected' : '' %>>they/them</option>
          <option value="she/they" <%= profile?.pronouns === 'she/they' ? 'selected' : '' %>>she/they</option>
          <option value="he/they" <%= profile?.pronouns === 'he/they' ? 'selected' : '' %>>he/they</option>
          <option value="ze/zir" <%= profile?.pronouns === 'ze/zir' ? 'selected' : '' %>>ze/zir</option>
          <option value="prefer not to say" <%= profile?.pronouns === 'prefer not to say' ? 'selected' : '' %>>Prefer not to say</option>
        </select>
      </label>

      <label>First name
        <input name="first_name" value="<%= profile?.first_name || '' %>" required />
      </label>

      <label>Surname
        <input name="surname" value="<%= profile?.surname || '' %>" required />
      </label>

      <label>Job title
        <input name="job_title" value="<%= profile?.job_title || '' %>" />
      </label>

      <label>Phone
        <input name="phone" type="tel" value="<%= profile?.phone || '' %>" />
        <p class="hint">Only enter your phone number if you are happy to be called from time to time by your Mentors</p>
      </label>

      <label>Location
        <select name="location_id" required>
          <option value="">Select location</option>
          <% locations.forEach((location) => { %>
            <option value="<%= location.id %>" <%= profile?.location_id === location.id ? 'selected' : '' %>><%= location.name %></option>
          <% }) %>
        </select>
      </label>
      <button class="btn" type="submit">Save Profile</button>
    </form>
  </section>
</main>
<%- include("../partials/footer") %>

<%- include("../partials/head", { title: "Mentee Dashboard" }) %>
<%- include("../partials/header") %>
<main class="container">
  <div class="inline-form wrap page-head-row">
    <h1>Mentee Dashboard</h1>
    <a class="btn ghost" href="/manuals/mentee-manual.html" target="_blank" rel="noopener noreferrer">Mentee Manual</a>
  </div>
  <%- include("../partials/flash") %>

  <section class="card">
    <h2>Find Mentors</h2>
    <form method="get" action="/mentee" class="inline-form wrap" id="find-mentors-form">
      <label>Select a location for where you need to find a mentor
        <select name="location_id" id="location_id_select" required>
          <option value="">Select location</option>
          <% locations.forEach((location) => { %>
            <option value="<%= location.id %>" <%= profile?.location_id === location.id ? 'selected' : '' %>><%= location.name %></option>
          <% }) %>
        </select>
      </label>

      <div id="function-section" style="display: <%= profile?.location_id ? 'block' : 'none' %>; margin-top: 1rem;">
        <p style="font-size: 0.9rem; color: var(--line); margin-bottom: 0.5rem;">Now select their function that you are interested in.</p>
        <label>Function
          <select name="section_id" id="section_id_select">
            <option value="">Select function</option>
            <% sections.forEach((section) => { %>
              <option value="<%= section.id %>" <%= selectedSectionId === section.id ? 'selected' : '' %>><%= section.name %></option>
            <% }) %>
          </select>
        </label>
      </div>

      <button class="btn" type="submit" id="show-mentors-btn" style="display: <%= profile?.location_id ? 'block' : 'none' %>; margin-top: 1rem;">Show Available Mentors</button>
    </form>

    <% if (profile?.location_id && selectedSectionId) { %>
      <% if (availableMentors.length === 0) { %>
        <p style="margin-top: 1rem;">No available mentors found for your location and selected function.</p>
      <% } else { %>
        <ul class="item-list mentors" style="margin-top: 1rem;">
          <% availableMentors.forEach((mentor) => { %>
            <li>
              <div>
                <strong><%= mentor.email %></strong>
                <p>Location: <%= mentor.location_name || 'N/A' %></p>
              </div>
              <form method="post" action="/mentee/request-mentor">
                <input type="hidden" name="mentor_id" value="<%= mentor.id %>" />
                <input type="hidden" name="section_id" value="<%= selectedSectionId %>" />
                <button class="btn" type="submit">Request Mentorship</button>
              </form>
            </li>
          <% }) %>
        </ul>
      <% } %>
    <% } %>
  </section>

  <script>
    document.getElementById('location_id_select').addEventListener('change', function() {
      const functionSection = document.getElementById('function-section');
      const showMentorsBtn = document.getElementById('show-mentors-btn');
      
      if (this.value) {
        functionSection.style.display = 'block';
        showMentorsBtn.style.display = 'block';
      } else {
        functionSection.style.display = 'none';
        showMentorsBtn.style.display = 'none';
        document.getElementById('section_id_select').value = '';
      }
    });
  </script>

  <section class="card">
    <h2>Your Mentorships</h2>
    <% if (mentorships.length === 0) { %>
      <p>No mentorships yet.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Mentor</th><th>Function</th><th>Status</th><th>Reason</th><th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% mentorships.forEach((item) => { %>
            <tr>
              <td><%= item.mentor_email %></td>
              <td><%= item.section_name || 'N/A' %></td>
              <td><%= item.status %></td>
              <td><%= item.end_reason_name || '-' %></td>
              <td>
                <div class="inline-form wrap">
                  <a class="btn compact goal-link <%= item.goalUnreadCount > 0 ? 'has-unread-goals' : '' %>" href="/mentee/mentorship/<%= item.id %>/goals" aria-label="Open updates <%= item.goalUnreadCount > 0 ? `(${item.goalUnreadCount} unread)` : '' %>">
                    Updates
                    <% if (item.goalUnreadCount > 0) { %>
                      <sup class="goal-count"><%= item.goalUnreadCount %></sup>
                    <% } %>
                  </a>
                <% if (item.status === 'accepted') { %>
                  <form method="post" action="/mentee/mentorship/<%= item.id %>/end" class="inline-form wrap">
                    <select name="end_reason_id" required>
                      <option value="">Live - Ended reason</option>
                      <% endReasons.forEach((reason) => { %>
                        <option value="<%= reason.id %>"><%= reason.name %></option>
                      <% }) %>
                    </select>
                    <button class="btn warning" type="submit">End</button>
                  </form>
                <% } else if (item.status === 'pending') { %>
                  <div class="inline-form wrap">
                    <form method="post" action="/mentee/mentorship/<%= item.id %>/resend">
                      <button class="btn" type="submit">Resend Request</button>
                    </form>
                    <form method="post" action="/mentee/mentorship/<%= item.id %>/cancel" onsubmit="return confirm('Remove this pending mentor request?');">
                      <button class="btn danger" type="submit">Remove Request</button>
                    </form>
                  </div>
                <% } else { %>
                  <span>-</span>
                <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>
<%- include("../partials/footer") %>

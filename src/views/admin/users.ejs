<%- include("../partials/head", { title: "Users" }) %>
<%- include("../partials/header") %>
<main class="container">
  <div class="inline-form wrap page-head-row">
    <h1>Users <%= roleFilter ? `(${roleFilter})` : '' %></h1>
    <div class="inline-form wrap">
      <a class="btn ghost" href="/admin/requests">Pending Requests</a>
      <a class="btn ghost" href="/admin/relationships">Live Relationships</a>
      <a class="btn ghost" href="/admin/history">Relationship History</a>
      <a class="btn ghost" href="/admin">Back to Admin</a>
    </div>
  </div>
  <%- include("../partials/flash") %>

  <% if (canManageAdmins) { %>
    <section class="card">
      <h2>Create Admin User</h2>
      <form method="post" action="/admin/users/admin" class="inline-form wrap" autocomplete="off">
        <input name="email" type="email" placeholder="Admin email" required />
        <input name="password" type="password" placeholder="Temporary password (min 8 chars)" minlength="8" required />
        <button class="btn" type="submit">Create Admin</button>
      </form>
      <p class="hint">Create a second admin for resilience, then ask them to change password at first login.</p>
    </section>
  <% } %>

  <section class="card">
    <% if (!users || users.length === 0) { %>
      <p>No users found.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <%- include("../partials/sortable-th", { sort, key: "id", label: "ID" }) %>
            <%- include("../partials/sortable-th", { sort, key: "user_name", label: "Name" }) %>
            <%- include("../partials/sortable-th", { sort, key: "role", label: "Role" }) %>
            <%- include("../partials/sortable-th", { sort, key: "location_name", label: "Location" }) %>
            <%- include("../partials/sortable-th", { sort, key: "active_mentor_count", label: "Active as Mentor" }) %>
            <%- include("../partials/sortable-th", { sort, key: "active_mentee_count", label: "Active as Mentee" }) %>
            <%- include("../partials/sortable-th", { sort, key: "created_at", label: "Created" }) %>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach((user) => { %>
            <tr>
              <td><%= user.id %></td>
              <td><%= user.user_name %></td>
              <td><%= user.role %><%= user.is_superadmin ? ' (superuser)' : '' %></td>
              <td><%= user.location_name || '-' %></td>
              <td><%= user.active_mentor_count %></td>
              <td><%= user.active_mentee_count %></td>
              <td><%= user.created_at %></td>
              <td>
                <div class="inline-form row-actions">
                  <% if (user.role !== 'admin' || canManageAdmins) { %>
                    <% if (!user.is_superadmin) { %>
                      <a class="btn ghost compact icon-btn" href="/admin/users/<%= user.id %>/edit" aria-label="Edit user" title="Edit user">
                        <span aria-hidden="true" class="icon-mark">
                          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                            <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z"/>
                            <path d="M20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                          </svg>
                        </span>
                        <span class="sr-only">Edit user</span>
                      </a>
                    <% } %>
                  <% } %>
                  <% if (user.role !== 'admin' || canManageAdmins) { %>
                    <form method="post" action="/admin/users/<%= user.id %>/resend-welcome">
                      <button class="btn ghost compact icon-btn" type="submit" aria-label="Resend welcome email" title="Resend welcome email">
                        <span aria-hidden="true" class="icon-mark">
                          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                            <path d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9Zm2.2-.5L12 11.2 17.8 7H6.2Zm11.3 10a.5.5 0 0 0 .5-.5V9.1l-5.5 4a1.2 1.2 0 0 1-1.4 0l-5.5-4V16.5a.5.5 0 0 0 .5.5h11.4Z"/>
                          </svg>
                        </span>
                        <span class="sr-only">Resend welcome email</span>
                      </button>
                    </form>
                  <% } %>

                  <% if (user.id !== currentUser.id && (user.role !== 'admin' || canManageAdmins)) { %>
                    <form method="post" action="/admin/users/<%= user.id %>/reset-password" onsubmit="return confirm('Send a password reset email to this user?');">
                      <button class="btn ghost compact icon-btn" type="submit" aria-label="Send password reset email" title="Send password reset email">
                        <span aria-hidden="true" class="icon-mark">
                          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                            <path d="M12 3.5a4.5 4.5 0 0 1 4.5 4.5v2h1A1.5 1.5 0 0 1 19 11.5v8A1.5 1.5 0 0 1 17.5 21h-11A1.5 1.5 0 0 1 5 19.5v-8A1.5 1.5 0 0 1 6.5 10h1V8A4.5 4.5 0 0 1 12 3.5Zm-3.5 6.5h7v-2a3.5 3.5 0 0 0-7 0v2Zm0 2v6h7v-6h-7Zm3.5 1.4a1.1 1.1 0 0 1 .7 1.96V17h-1.4v-1.14A1.1 1.1 0 0 1 12 13.4Z"/>
                          </svg>
                        </span>
                        <span class="sr-only">Send password reset email</span>
                      </button>
                    </form>
                  <% } %>

                  <% if (user.id === currentUser.id || (user.role === 'admin' && !canManageAdmins) || user.is_superadmin) { %>
                    <span>-</span>
                  <% } else { %>
                    <form method="post" action="/admin/users/<%= user.id %>/delete" onsubmit="return confirm('Delete this user and all related data? This cannot be undone.');">
                      <button class="btn danger compact icon-btn" type="submit" aria-label="Delete user" title="Delete user">
                        <span aria-hidden="true" class="icon-mark">
                          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                            <path d="M9 3.5A1.5 1.5 0 0 0 7.5 5H5.8a.8.8 0 0 0 0 1.6h.8l.7 10.7A2 2 0 0 0 9.3 19h5.4a2 2 0 0 0 2-1.7l.7-10.7h.8a.8.8 0 0 0 0-1.6h-1.7A1.5 1.5 0 0 0 15 3.5H9Zm0 1.6h6a.1.1 0 0 1 .1.1v.8H8.9v-.8a.1.1 0 0 1 .1-.1Zm-.7 3h7.4l-.6 9.8a.4.4 0 0 1-.4.4H9.3a.4.4 0 0 1-.4-.4L8.3 8.1Zm2 1.7a.8.8 0 0 0-.8.8v4.2a.8.8 0 0 0 1.6 0v-4.2a.8.8 0 0 0-.8-.8Zm3.2 0a.8.8 0 0 0-.8.8v4.2a.8.8 0 0 0 1.6 0v-4.2a.8.8 0 0 0-.8-.8Z"/>
                          </svg>
                        </span>
                        <span class="sr-only">Delete user</span>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>
<%- include("../partials/footer") %>

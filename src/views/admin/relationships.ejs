<%- include("../partials/head", { title: "Live Relationships" }) %>
<%- include("../partials/header") %>
<main class="container">
  <div class="inline-form wrap page-head-row">
    <h1>Live Relationships</h1>
    <div class="inline-form wrap">
      <a class="btn ghost" href="/admin/requests">Pending Requests</a>
      <a class="btn ghost" href="/admin/users?role=mentor">Mentors</a>
      <a class="btn ghost" href="/admin/users?role=mentee">Mentees</a>
      <a class="btn ghost" href="/admin">Back to Admin</a>
    </div>
  </div>
  <%- include("../partials/flash") %>

  <section class="card">
    <% if (!rows || rows.length === 0) { %>
      <p>No live relationships.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <%- include("../partials/sortable-th", { sort, key: "id", label: "ID" }) %>
            <%- include("../partials/sortable-th", { sort, key: "mentee_name", label: "Mentee" }) %>
            <%- include("../partials/sortable-th", { sort, key: "mentor_name", label: "Mentor" }) %>
            <%- include("../partials/sortable-th", { sort, key: "location_name", label: "Location" }) %>
            <%- include("../partials/sortable-th", { sort, key: "section_name", label: "Function" }) %>
            <%- include("../partials/sortable-th", { sort, key: "updated_at", label: "Updated" }) %>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((row) => { %>
            <tr>
              <td><%= row.id %></td>
              <td><%= row.mentee_name %></td>
              <td><%= row.mentor_name %></td>
              <td><%= row.location_name || '-' %></td>
              <td><%= row.section_name || '-' %></td>
              <td><%= row.updated_at %></td>
              <td>
                <form method="post" action="/admin/relationships/<%= row.id %>/remove" onsubmit="return confirm('Remove this live relationship?');">
                  <button class="btn danger" type="submit">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>
<%- include("../partials/footer") %>

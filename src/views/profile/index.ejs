<%- include("../partials/head", { title: "Profile" }) %>
<%- include("../partials/header") %>
<main class="container">
  <h1>Profile</h1>
  <%- include("../partials/flash") %>

  <section class="card" style="margin-bottom: 1rem;">
    <h2>Account Information</h2>
    <% if (isAdmin) { %>
      <form method="post" action="/profile/role" class="form-grid" autocomplete="off">
        <label>Role(s)
          <select name="role">
            <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
            <option value="mentor" <%= user.role === 'mentor' ? 'selected' : '' %>>Mentor</option>
            <option value="mentee" <%= user.role === 'mentee' ? 'selected' : '' %>>Mentee</option>
            <option value="both" <%= user.role === 'both' ? 'selected' : '' %>>Mentor & Mentee</option>
          </select>
        </label>
        <button class="btn" type="submit">Update Role</button>
      </form>
    <% } else { %>
      <div class="form-grid">
        <label>Role(s)
          <div style="padding: 0.5rem; background: var(--bg-soft); border-radius: 4px; border: 1px solid var(--line);">
            <%= user.role === 'both' ? 'Mentor & Mentee' : (user.role.charAt(0).toUpperCase() + user.role.slice(1)) %>
          </div>
        </label>
      </div>
    <% } %>
  </section>

  <section class="card" style="margin-bottom: 1rem;">
    <h2>Personal Details</h2>
    <form method="post" action="/profile/details" class="form-grid" autocomplete="off">
      <label>Title
        <select name="title">
          <option value="" <%= !user.title ? 'selected' : '' %>>Select title</option>
          <option value="Mr" <%= user.title === 'Mr' ? 'selected' : '' %>>Mr</option>
          <option value="Mrs" <%= user.title === 'Mrs' ? 'selected' : '' %>>Mrs</option>
          <option value="Ms" <%= user.title === 'Ms' ? 'selected' : '' %>>Ms</option>
          <option value="Miss" <%= user.title === 'Miss' ? 'selected' : '' %>>Miss</option>
          <option value="Mx" <%= user.title === 'Mx' ? 'selected' : '' %>>Mx</option>
          <option value="Dr" <%= user.title === 'Dr' ? 'selected' : '' %>>Dr</option>
          <option value="Prof" <%= user.title === 'Prof' ? 'selected' : '' %>>Prof</option>
          <option value="Rev" <%= user.title === 'Rev' ? 'selected' : '' %>>Rev</option>
        </select>
      </label>
      <label>Pronouns
        <select name="pronouns">
          <option value="" <%= !user.pronouns ? 'selected' : '' %>>Select pronouns</option>
          <option value="she/her" <%= user.pronouns === 'she/her' ? 'selected' : '' %>>she/her</option>
          <option value="he/him" <%= user.pronouns === 'he/him' ? 'selected' : '' %>>he/him</option>
          <option value="they/them" <%= user.pronouns === 'they/them' ? 'selected' : '' %>>they/them</option>
          <option value="she/they" <%= user.pronouns === 'she/they' ? 'selected' : '' %>>she/they</option>
          <option value="he/they" <%= user.pronouns === 'he/they' ? 'selected' : '' %>>he/they</option>
          <option value="ze/zir" <%= user.pronouns === 'ze/zir' ? 'selected' : '' %>>ze/zir</option>
          <option value="prefer not to say" <%= user.pronouns === 'prefer not to say' ? 'selected' : '' %>>Prefer not to say</option>
        </select>
      </label>
      <label>First name
        <input type="text" name="first_name" value="<%= user.first_name || '' %>" required />
      </label>
      <label>Surname
        <input type="text" name="surname" value="<%= user.surname || '' %>" required />
      </label>
      <label>Job title
        <input type="text" name="job_title" value="<%= user.job_title || '' %>" />
      </label>
      <label>Phone
        <input type="tel" name="phone" value="<%= user.phone || '' %>" />
        <% if (user.role === 'mentor' || user.role === 'both') { %>
          <p class="hint">Only enter your phone number if you are happy to be called from time to time by your Mentees</p>
        <% } else if (user.role === 'mentee') { %>
          <p class="hint">Only enter your phone number if you are happy to be called from time to time by your Mentors</p>
        <% } %>
      </label>
      <button class="btn" type="submit">Update Profile</button>
    </form>
  </section>

  <section class="grid-2">
    <article class="card">
      <h2>Change Email</h2>
      <form method="post" action="/profile/email" class="form-grid" autocomplete="off">
        <label>New Email
          <input type="text" name="email" value="<%= user.email %>" required />
        </label>
        <label>Current Password
          <div class="password-row">
            <input id="email-current-password" type="password" name="currentPassword" required autocomplete="current-password" />
            <button type="button" class="btn ghost toggle-password" data-target="email-current-password">Show</button>
          </div>
        </label>
        <button class="btn" type="submit">Update Email</button>
      </form>
    </article>

    <article class="card">
      <h2>Change Password</h2>
      <form method="post" action="/profile/password" class="form-grid" autocomplete="on">
        <label>Current Password
          <div class="password-row">
            <input id="current-password" type="password" name="currentPassword" required autocomplete="current-password" />
            <button type="button" class="btn ghost toggle-password" data-target="current-password">Show</button>
          </div>
        </label>
        <label>New Password
          <div class="password-row">
            <input id="new-password" type="password" name="newPassword" minlength="6" required autocomplete="new-password" />
            <button type="button" class="btn ghost toggle-password" data-target="new-password">Show</button>
          </div>
        </label>
        <button class="btn" type="submit">Update Password</button>
      </form>
    </article>
  </section>

  <section class="card" style="margin-bottom: 1rem;">
    <h2>Two-Factor Authentication (Authenticator App)</h2>
    <% if (Number(user.twofa_enabled) === 1) { %>
      <p class="hint">2FA is currently enabled for your account.</p>
      <form method="post" action="/profile/2fa/disable" class="form-grid" autocomplete="off">
        <label>Current Password
          <div class="password-row">
            <input id="disable-2fa-password" type="password" name="currentPassword" required autocomplete="current-password" />
            <button type="button" class="btn ghost toggle-password" data-target="disable-2fa-password">Show</button>
          </div>
        </label>
        <label>Authenticator Code
          <input name="token" required inputmode="numeric" pattern="[0-9]{6}" minlength="6" maxlength="6" placeholder="123456" autocomplete="one-time-code" />
        </label>
        <button class="btn warning" type="submit">Disable 2FA</button>
      </form>
    <% } else if (pendingTwoFactorSetup) { %>
      <p class="hint">Scan this QR code in Authy (or another authenticator app), then enter the 6-digit code to confirm.</p>
      <% if (pendingTwoFactorSetup.qrCodeDataUrl) { %>
        <p><img src="<%= pendingTwoFactorSetup.qrCodeDataUrl %>" alt="2FA QR code" style="max-width: 220px; border: 1px solid var(--line); border-radius: 10px; padding: 0.4rem; background: var(--paper);" /></p>
      <% } %>
      <p class="hint"><strong>Manual key:</strong> <%= pendingTwoFactorSetup.secret %></p>
      <form method="post" action="/profile/2fa/enable" class="form-grid" autocomplete="off">
        <label>Authenticator Code
          <input name="token" required inputmode="numeric" pattern="[0-9]{6}" minlength="6" maxlength="6" placeholder="123456" autocomplete="one-time-code" />
        </label>
        <button class="btn" type="submit">Enable 2FA</button>
      </form>
      <form method="post" action="/profile/2fa/cancel" class="inline-form wrap" style="margin-top: 0.6rem;">
        <button class="btn ghost" type="submit">Cancel Setup</button>
      </form>
    <% } else { %>
      <p class="hint">Add an extra login step with an authenticator app such as Authy.</p>
      <form method="post" action="/profile/2fa/setup" class="form-grid" autocomplete="off">
        <label>Current Password
          <div class="password-row">
            <input id="enable-2fa-password" type="password" name="currentPassword" required autocomplete="current-password" />
            <button type="button" class="btn ghost toggle-password" data-target="enable-2fa-password">Show</button>
          </div>
        </label>
        <button class="btn" type="submit">Set Up 2FA</button>
      </form>
    <% } %>
  </section>
</main>
<%- include("../partials/footer") %>

<%- include("../partials/head", { title: "Reset Password" }) %>
<%- include("../partials/header") %>
<main class="container auth-wrap">
  <section class="card">
    <h1>Reset Password</h1>
    <%- include("../partials/flash") %>
    <form method="post" action="/reset-password/<%= token %>" class="form-grid" autocomplete="on">
      <label>New Password
        <div class="password-row">
          <input id="reset-password" type="password" name="password" required minlength="6" autocomplete="new-password" />
          <button type="button" class="btn ghost toggle-password" data-target="reset-password">Show</button>
        </div>
      </label>
      <button type="submit" class="btn">Update Password</button>
    </form>
  </section>
</main>
<%- include("../partials/footer") %>
